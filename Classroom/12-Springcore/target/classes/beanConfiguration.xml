<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans.xsd">
    <bean id="LaptopId" class="iocwithxml.Laptop">
        <property name="price" value="1234"/>
        <property name="model" value="HP"/>
        <property name="chipSet" value="Intel i5"/>
    </bean>
    <bean id="LaptopId1" class="iocwithxml.Laptop">
        <property name="price" value="1245"/>
        <property name="model" value="Dell"/>
        <property name="chipSet" value="Ryzen 5"/>
    </bean>

</beans>
